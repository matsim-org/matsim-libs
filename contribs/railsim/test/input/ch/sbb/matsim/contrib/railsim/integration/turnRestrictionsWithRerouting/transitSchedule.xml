				<stop refId="B" departureOffset="24:00:00" arrivalOffset="24:00:00" awaitDeparture="true"/>
			</routeProfile>
			<route>
				<link refId="stop_loop_1"/>
				<link refId="1"/>
				<link refId="2"/>
				<link refId="3"/>
			</route>
			<departures>
				<departure id="dep_1" departureTime="00:00:00" vehicleRefId="pt_1_veh_1"/>
			</departures>
		</transitRoute>
		<transitRoute id="pass">
			<transportMode>rail</transportMode>
			<routeProfile>
				<stop refId="A" departureOffset="00:00:00" arrivalOffset="00:00:00" awaitDeparture="true"/>
				<stop refId="C" departureOffset="00:05:00" arrivalOffset="00:05:00" awaitDeparture="true"/>
			</routeProfile>
			<route>
				<link refId="stop_loop_1"/>
				<link refId="1"/>
				<link refId="2"/>
				<link refId="3"/>
				<link refId="4"/>
				<link refId="5"/>
				<link refId="stop_loop_6"/>
			</route>
			<departures>
				<departure id="dep_1" departureTime="00:01:00" vehicleRefId="pt_1_veh_2"/>
			</departures>
		</transitRoute>
	</transitLine>
</transitSchedule>
