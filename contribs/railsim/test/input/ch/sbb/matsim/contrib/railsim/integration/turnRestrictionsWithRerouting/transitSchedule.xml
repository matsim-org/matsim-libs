<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE transitSchedule SYSTEM "http://www.matsim.org/files/dtd/transitSchedule_v2.dtd">
<transitSchedule>
	<transitStops>
		<stopFacility id="A" x="0" y="0" linkRefId="stop_loop_1" name="A" isBlocking="false"/>
		<stopFacility id="B" x="3000" y="0.0" linkRefId="3" name="C" isBlocking="false"/>
		<stopFacility id="C" x="5500" y="0.0" linkRefId="stop_loop_6" name="B" isBlocking="false"/>
	</transitStops>
	<transitLine id="line">
		<transitRoute id="stop">
			<transportMode>rail</transportMode>
			<routeProfile>
				<stop refId="A" departureOffset="00:00:00" arrivalOffset="00:00:00" awaitDeparture="true"/>
